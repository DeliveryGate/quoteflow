# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products,read_draft_orders,write_draft_orders,read_customers
SHOPIFY_APP_URL=https://quoteflow.railway.app

# Database
DATABASE_URL=postgresql://
DIRECT_URL=postgresql://

# Email (optional SMTP)
EMAIL_FROM=quotes@quoteflow.app
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Runtime
NODE_ENV=development
PORT=3000
